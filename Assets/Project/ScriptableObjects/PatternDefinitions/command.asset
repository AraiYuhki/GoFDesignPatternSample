  patternId: command
  displayName: Command
  displayNameJp: "\u30B3\u30DE\u30F3\u30C9"
  category: 2
  summary: "\u64CD\u4F5C\u3092\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u3068\u3057\u3066\u30AB\u30D7\u30BB\u30EB\u5316\u3057\u3001Undo/Redo\u3084\u64CD\u4F5C\u306E\u30AD\u30E5\u30FC\u5316\u3092\u53EF\u80FD\u306B\u3059\u308B"
  description: "Command\u30D1\u30BF\u30FC\u30F3\u306F\u64CD\u4F5C\u3092\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u3068\u3057\u3066\u30AB\u30D7\u30BB\u30EB\u5316\u3059\u308B\u8A2D\u8A08\u30D1\u30BF\u30FC\u30F3\u3067\u3059\u3002Invoker\u304C\u5177\u4F53\u7684\u306A\u51E6\u7406\u3092\u77E5\u3089\u306A\u304F\u3066\u3082\u30B3\u30DE\u30F3\u30C9\u3092\u5B9F\u884C\u3067\u304D\u3001\u5C65\u6B74\u7BA1\u7406\u306B\u3088\u308BUndo/Redo\u3084\u30DE\u30AF\u30ED\u8A18\u9332\u304C\u5BB9\u6613\u306B\u306A\u308A\u307E\u3059\u3002"
  problemToSolve: "\u64CD\u4F5C\u306E\u53D6\u308A\u6D88\u3057\u30FB\u3084\u308A\u76F4\u3057\u3001\u64CD\u4F5C\u306E\u30AD\u30E5\u30FC\u5316\u3084\u30ED\u30B0\u8A18\u9332\u304C\u5FC5\u8981\u306A\u5834\u9762\u3002\u4F8B:
    \u30A8\u30C7\u30A3\u30BF\u64CD\u4F5C\u3001\u30B2\u30FC\u30E0\u30B3\u30DE\u30F3\u30C9"
  whenToUse: "Undo/Redo\u304C\u5FC5\u8981\u306A\u5834\u5408\u3001\u64CD\u4F5C\u3092\u5F8C\u304B\u3089\u5B9F\u884C\u30FB\u518D\u5B9F\u884C\u3057\u305F\u3044\u5834\u5408\u3001\u64CD\u4F5C\u306E\u8A18\u9332\u3084\u518D\u751F\u304C\u5FC5\u8981\u306A\u5834\u5408"
  advantages: "Undo/Redo\u304C\u5BB9\u6613\u3001\u64CD\u4F5C\u306E\u30AD\u30E5\u30FC\u5316\u30FB\u30B9\u30B1\u30B8\u30E5\u30FC\u30EA\u30F3\u30B0\u304C\u53EF\u80FD\u3001Invoker\u3068Receiver\u304C\u758E\u7D50\u5408"
  disadvantages: "\u30B3\u30DE\u30F3\u30C9\u30AF\u30E9\u30B9\u304C\u591A\u6570\u306B\u306A\u308A\u3084\u3059\u3044\u3001\u30B7\u30F3\u30D7\u30EB\u306A\u64CD\u4F5C\u306B\u306F\u904E\u5270\u306A\u5834\u5408\u304C\u3042\u308B"
  participants: []
  relatedPatternIds: []
  stepDescriptions: []
