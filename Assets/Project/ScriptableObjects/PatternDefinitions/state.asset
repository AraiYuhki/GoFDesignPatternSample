  patternId: state
  displayName: State
  displayNameJp: "\u30B9\u30C6\u30FC\u30C8"
  category: 2
  summary: "\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u306E\u5185\u90E8\u72B6\u614B\u306B\u5FDC\u3058\u3066\u632F\u308B\u821E\u3044\u3092\u5909\u5316\u3055\u305B\u308B"
  description: "State\u30D1\u30BF\u30FC\u30F3\u306F\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u306E\u5185\u90E8\u72B6\u614B\u304C\u5909\u5316\u3057\u305F\u3068\u304D\u3001\u305D\u306E\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u306E\u30AF\u30E9\u30B9\u304C\u5909\u308F\u3063\u305F\u3088\u3046\u306B\u632F\u308B\u821E\u3044\u3092\u5909\u3048\u308B\u8A2D\u8A08\u30D1\u30BF\u30FC\u30F3\u3067\u3059\u3002\u72B6\u614B\u3054\u3068\u306E\u30ED\u30B8\u30C3\u30AF\u3092State\u30AF\u30E9\u30B9\u306B\u5206\u96E2\u3059\u308B\u3053\u3068\u3067switch\u6587\u306E\u80A5\u5927\u5316\u3092\u9632\u304E\u307E\u3059\u3002"
  problemToSolve: "\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u304C\u72B6\u614B\u306B\u3088\u3063\u3066\u632F\u308B\u821E\u3044\u304C\u5927\u304D\u304F\u5909\u308F\u308B\u5834\u9762\u3002\u4F8B:
    \u30AD\u30E3\u30E9\u30AF\u30BF\u30FC\u306EAI\u72B6\u614B\u3001UI\u306E\u30E2\u30FC\u30C9\u5207\u308A\u66FF\u3048"
  whenToUse: "\u72B6\u614B\u3054\u3068\u306B\u8907\u96D1\u306A\u6761\u4EF6\u5206\u5C90\u304C\u767A\u751F\u3057\u3066\u3044\u308B\u5834\u5408\u3001\u72B6\u614B\u9077\u79FB\u304C\u591A\u6570\u3042\u308B\u5834\u5408"
  advantages: "\u72B6\u614B\u3054\u3068\u306E\u30B3\u30FC\u30C9\u304C\u660E\u78BA\u306B\u5206\u96E2\u3055\u308C\u308B\u3001\u72B6\u614B\u8FFD\u52A0\u304C\u5BB9\u6613\u3001switch/if-else\u306E\u80A5\u5927\u5316\u3092\u9632\u3052\u308B"
  disadvantages: "\u30AF\u30E9\u30B9\u6570\u304C\u5897\u3048\u308B\u3001\u5358\u7D14\u306A\u72B6\u614B\u7BA1\u7406\u306B\u306F\u904E\u5270\u306A\u5834\u5408\u304C\u3042\u308B"
  participants: []
  relatedPatternIds: []
  stepDescriptions: []
