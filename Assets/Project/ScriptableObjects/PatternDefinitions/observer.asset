  patternId: observer
  displayName: Observer
  displayNameJp: "\u30AA\u30D6\u30B6\u30FC\u30D0\u30FC"
  category: 2
  summary: "\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u306E\u72B6\u614B\u5909\u5316\u3092\u8907\u6570\u306E\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u3078\u81EA\u52D5\u7684\u306B\u901A\u77E5\u30FB\u66F4\u65B0\u3059\u308B"
  description: "Observer\u30D1\u30BF\u30FC\u30F3\u306F\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\uFF08Subject\uFF09\u306E\u72B6\u614B\u5909\u5316\u3092\u3001\u305D\u308C\u306B\u4F9D\u5B58\u3059\u308B\u8907\u6570\u306E\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\uFF08Observer\uFF09\u3078\u81EA\u52D5\u7684\u306B\u901A\u77E5\u3059\u308B\u8A2D\u8A08\u30D1\u30BF\u30FC\u30F3\u3067\u3059\u3002Subject\u306FObserver\u306E\u5177\u4F53\u7684\u306A\u30AF\u30E9\u30B9\u3092\u77E5\u3089\u305A\u306B\u901A\u77E5\u3067\u304D\u307E\u3059\u3002"
  problemToSolve: "\u3042\u308B\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u306E\u72B6\u614B\u5909\u5316\u3092\u8907\u6570\u306E\u4ED6\u306E\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u306B\u53CD\u6620\u3057\u305F\u3044\u5834\u9762\u3002\u4F8B:
    HP\u5909\u5316\u2192HUD\u66F4\u65B0+SE\u518D\u751F+\u5B9F\u7E3E\u78BA\u8A8D"
  whenToUse: "1\u5BFE\u591A\u306E\u4F9D\u5B58\u95A2\u4FC2\u3092\u8A2D\u5B9A\u3057\u3001\u4E00\u65B9\u306E\u5909\u5316\u304C\u4ED6\u306B\u4F1D\u308F\u308B\u3088\u3046\u306B\u3057\u305F\u3044\u5834\u5408"
  advantages: "Subject\u3068Observer\u304C\u758E\u7D50\u5408\u306B\u306A\u308B\u3001Observer\u306E\u8FFD\u52A0\u30FB\u524A\u9664\u304C\u52D5\u7684\u306B\u884C\u3048\u308B\u3001\u518D\u5229\u7528\u6027\u304C\u9AD8\u3044"
  disadvantages: "\u901A\u77E5\u306E\u9023\u9396\u3067\u4E88\u671F\u3057\u306A\u3044\u66F4\u65B0\u304C\u8D77\u304D\u308B\u5834\u5408\u304C\u3042\u308B\u3001Observer\u304C\u5897\u3048\u308B\u3068\u30D1\u30D5\u30A9\u30FC\u30DE\u30F3\u30B9\u306B\u5F71\u97FF\u3059\u308B\u3053\u3068\u304C\u3042\u308B"
