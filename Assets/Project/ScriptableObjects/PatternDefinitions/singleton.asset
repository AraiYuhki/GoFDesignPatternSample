  patternId: singleton
  displayName: Singleton
  displayNameJp: "\u30B7\u30F3\u30B0\u30EB\u30C8\u30F3"
  category: 0
  summary: "\u30AF\u30E9\u30B9\u306E\u30A4\u30F3\u30B9\u30BF\u30F3\u30B9\u30921\u3064\u306B\u5236\u9650\u3057\u3001\u30B0\u30ED\u30FC\u30D0\u30EB\u30A2\u30AF\u30BB\u30B9\u30DD\u30A4\u30F3\u30C8\u3092\u63D0\u4F9B\u3059\u308B"
  description: "Singleton\u30D1\u30BF\u30FC\u30F3\u306F\u30AF\u30E9\u30B9\u304C\u6301\u3064\u30A4\u30F3\u30B9\u30BF\u30F3\u30B9\u3092\u552F\u4E00\u306E1\u500B\u306B\u5236\u9650\u3059\u308B\u8A2D\u8A08\u30D1\u30BF\u30FC\u30F3\u3067\u3059\u3002private\u30B3\u30F3\u30B9\u30C8\u30E9\u30AF\u30BF\u3067\u5916\u90E8\u304B\u3089\u306E\u751F\u6210\u3092\u7981\u6B62\u3057\u3001static\u306AInstance\u30D7\u30ED\u30D1\u30C6\u30A3\u3092\u901A\u3058\u3066\u306E\u307F\u30A2\u30AF\u30BB\u30B9\u3092\u8A31\u53EF\u3057\u307E\u3059\u3002"
  problemToSolve: "\u8907\u6570\u306E\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u304C\u540C\u3058\u30EA\u30BD\u30FC\u30B9\u3084\u72B6\u614B\u3092\u5171\u6709\u3059\u308B\u5FC5\u8981\u304C\u3042\u308B\u5834\u9762\u3002\u4F8B:
    GameManager\u3001\u8A2D\u5B9A\u7BA1\u7406\u3001\u30ED\u30B0\u30B7\u30B9\u30C6\u30E0"
  whenToUse: "\u30B0\u30ED\u30FC\u30D0\u30EB\u72B6\u614B\u306E\u5171\u6709\u304C\u5FC5\u8981\u306A\u5834\u5408\u3001\u8907\u6570\u30A4\u30F3\u30B9\u30BF\u30F3\u30B9\u304C\u77DB\u76FE\u3092\u8D77\u3053\u3059\u6050\u308C\u304C\u3042\u308B\u5834\u5408"
  advantages: "\u30A4\u30F3\u30B9\u30BF\u30F3\u30B9\u7BA1\u7406\u304C\u5358\u7D14\u5316\u3055\u308C\u308B\u3001\u30B0\u30ED\u30FC\u30D0\u30EB\u30A2\u30AF\u30BB\u30B9\u304C\u5BB9\u6613\u3001\u521D\u671F\u5316\u30BF\u30A4\u30DF\u30F3\u30B0\u306E\u5236\u5FA1\u304C\u53EF\u80FD"
  disadvantages: "\u30B0\u30ED\u30FC\u30D0\u30EB\u72B6\u614B\u306B\u3088\u308A\u30C6\u30B9\u30C8\u304C\u56F0\u96E3\u306B\u306A\u308B\u3001\u4F9D\u5B58\u95A2\u4FC2\u304C\u96A0\u308C\u308B\u3001\u4E26\u5217\u51E6\u7406\u3067\u6CE8\u610F\u304C\u5FC5\u8981"
  participants: []
  relatedPatternIds: []
  stepDescriptions: []
