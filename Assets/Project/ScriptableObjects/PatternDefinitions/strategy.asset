  m_Script: {fileID: 11500000, guid: 6f8bd0b7fa66b400686075734ad2c576, type: 3}
  m_Name: strategy
  m_EditorClassIdentifier: GoFPatterns.Core::GoFPatterns.Core.PatternDefinition
  patternId: strategy
  displayName: Strategy
  displayNameJp: "\u30B9\u30C8\u30E9\u30C6\u30B8\u30FC"
  category: 2
  summary: "\u30A2\u30EB\u30B4\u30EA\u30BA\u30E0\u306E\u30D5\u30A1\u30DF\u30EA\u30FC\u3092\u5B9A\u7FA9\u3057\u3001\u5B9F\u884C\u6642\u306B\u4EA4\u63DB\u53EF\u80FD\u306B\u3059\u308B"
  description: "Strategy\u30D1\u30BF\u30FC\u30F3\u306F\u30A2\u30EB\u30B4\u30EA\u30BA\u30E0\u3092\u305D\u308C\u305E\u308C\u306E\u30AF\u30E9\u30B9\u306B\u30AB\u30D7\u30BB\u30EB\u5316\u3057\u3001\u540C\u3058\u30A4\u30F3\u30BF\u30FC\u30D5\u30A7\u30FC\u30B9\u3092\u6301\u3064\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u3068\u3057\u3066\u4EA4\u63DB\u53EF\u80FD\u306B\u3059\u308B\u8A2D\u8A08\u30D1\u30BF\u30FC\u30F3\u3067\u3059\u3002\u30B3\u30F3\u30C6\u30AD\u30B9\u30C8\u306F\u4F7F\u7528\u3059\u308B\u6226\u7565\u3092\u5B9F\u884C\u6642\u306B\u5909\u66F4\u3067\u304D\u307E\u3059\u3002"
  problemToSolve: "\u540C\u4E00\u306E\u51E6\u7406\u306B\u8907\u6570\u306E\u30A2\u30EB\u30B4\u30EA\u30BA\u30E0\u304C\u5FC5\u8981\u3067\u3001\u5B9F\u884C\u6642\u306B\u5207\u308A\u66FF\u3048\u305F\u3044\u5834\u9762\u3002\u4F8B:
    \u30BD\u30FC\u30C8\u30A2\u30EB\u30B4\u30EA\u30BA\u30E0\u3001\u653B\u6483\u30D1\u30BF\u30FC\u30F3\u3001\u7D4C\u8DEF\u63A2\u7D22"
  whenToUse: "\u30A2\u30EB\u30B4\u30EA\u30BA\u30E0\u306E\u5909\u66F4\u304C\u30B3\u30F3\u30C6\u30AD\u30B9\u30C8\u306B\u5F71\u97FF\u3057\u306A\u3044\u3088\u3046\u306B\u3057\u305F\u3044\u5834\u5408\u3001if/else\u306E\u5206\u5C90\u3092\u6E1B\u3089\u3057\u305F\u3044\u5834\u5408"
  advantages: "\u30A2\u30EB\u30B4\u30EA\u30BA\u30E0\u306E\u4EA4\u63DB\u304C\u5BB9\u6613\u3001\u30B3\u30F3\u30C6\u30AD\u30B9\u30C8\u3068\u30A2\u30EB\u30B4\u30EA\u30BA\u30E0\u304C\u758E\u7D50\u5408\u3001\u65B0\u6226\u7565\u306E\u8FFD\u52A0\u304C\u5BB9\u6613"
  disadvantages: "\u6226\u7565\u30AF\u30E9\u30B9\u304C\u5897\u52A0\u3057\u3084\u3059\u3044\u3001\u30AF\u30E9\u30A4\u30A2\u30F3\u30C8\u304C\u5404\u6226\u7565\u306E\u9055\u3044\u3092\u628A\u63E1\u3059\u308B\u5FC5\u8981\u304C\u3042\u308B"
  participants: []
  relatedPatternIds: []
  stepDescriptions: []
